              ],
              "path": [
                "bots",
                "{{botId}}",
                "events"
              ]
            }
          }
        },
        {
          "name": "Get Command",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/commands/{{commandId}}",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "commands",
                "{{commandId}}"
              ]
            }
          }
        },
        {
          "name": "List Meetings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings"
              ]
            }
          }
        },
        {
          "name": "Get Meeting",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Timeline",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/timeline?limit=100",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "timeline"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Get Meeting Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/events",
              "host": [
