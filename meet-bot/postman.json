              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "events"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/messages",
              "host": [
