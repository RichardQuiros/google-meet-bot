                "{{meetingId}}",
                "messages"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Captions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/captions",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "captions"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Audio Transcripts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/audio-transcripts",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "audio-transcripts"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Video Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/video-events",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "video-events"
              ]
            }
          }
        },
        {
          "name": "Get Latest Video Frame",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/video-frames/latest",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "video-frames",
                "latest"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.eventId) {",
                  "  pm.collectionVariables.set('frameId', json.eventId);",
                  "}",
                  "pm.test('Latest frame request succeeded', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Video Frame Image",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/video-frames/{{frameId}}/image",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "video-frames",
                "{{frameId}}",
                "image"
              ]
            },
            "description": "Fetches the JPEG bytes for the most recent frame after running Get Latest Video Frame."
          }
        },
        {
          "name": "Get Meeting Commands",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/commands",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "commands"
              ]
            }
          }
        },
        {
          "name": "Stream Meeting Events (Live)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/meetings/{{meetingId}}/events/stream?snapshotLimit=0",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "meetings",
                "{{meetingId}}",
                "events",
                "stream"
              ],
              "query": [
                {
                  "key": "snapshotLimit",
                  "value": "0"
                }
              ]
            },
            "description": "Opens the live SSE stream without an initial snapshot backlog. This is the recommended mode for near-live agent consumption."
          }
        }
      ]
    },
    {
      "name": "Internal Runtime API",
      "item": [
        {
          "name": "Register Runtime Bot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"botId\": \"{{botId}}\",\n  \"displayName\": \"{{displayName}}\"\n}"
            },
            "url": {
              "raw": "{{controlServerUrl}}/internal/bots/register",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "internal",
                "bots",
                "register"
              ]
            }
          }
        },
        {
          "name": "Poll Next Command (Long Poll)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{controlServerUrl}}/internal/bots/{{botId}}/commands/next?waitMs=3000",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "internal",
                "bots",
                "{{botId}}",
                "commands",
                "next"
              ],
              "query": [
                {
                  "key": "waitMs",
                  "value": "3000"
                }
              ]
            }
          }
        },
        {
          "name": "Post Bot Status Changed Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"bot.status.changed\",\n  \"botId\": \"{{botId}}\",\n  \"meetingId\": \"{{meetingId}}\",\n  \"payload\": {\n    \"status\": \"joined\"\n  },\n  \"timestamp\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": {
              "raw": "{{controlServerUrl}}/internal/events",
              "host": [
                "{{controlServerUrl}}"
              ],
              "path": [
                "internal",
                "events"
              ]
            }
          }
        }
      ]
    }
  ]
